{
  "name": "@credat/mcp",
  "version": "0.1.2-alpha.1",
  "description": "Trust & authentication layer for MCP servers — verify agent identity, delegated permissions, and scopes using Credat",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "authentication",
    "authorization",
    "trust",
    "agent",
    "delegation",
    "verifiable-credentials",
    "did",
    "credat",
    "ai-agent",
    "middleware"
  ],
  "author": "Maxime Mansiet",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/credat/credat-mcp.git"
  },
  "homepage": "https://github.com/credat/credat-mcp#readme",
  "bugs": {
    "url": "https://github.com/credat/credat-mcp/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@credat/sdk": "^0.3.0-alpha.1",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@credat/sdk": "^0.3.0-alpha.1",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^3.25.0"
  }
}
